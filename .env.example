# Get your API key at https://dashboard.remote-backups.com/settings/security
# Token scope: monitoring
API_KEY=your_api_key_here

# --- Web UI authentication (optional) ---

# Protect the dashboard with a password. Leave empty to disable authentication
# (safe when Traefik/OAuth2 proxy handles access control at the network edge).
WEBUI_PASSWORD=

# Secret key for signing Flask session cookies. Generate a strong random value,
# e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
# If unset and WEBUI_PASSWORD is configured, a random key is generated at startup
# (sessions are invalidated on each container restart).
WEBUI_SECRET_KEY=

# ntfy authentication token. When set, this overrides the ntfy_token stored in
# config.json. Prefer this over storing the token on disk.
# e.g.: NTFY_TOKEN=tk_yoursecrettoken
NTFY_TOKEN=

# --- Web UI settings ---

# Port the web server listens on (default: 5111)
WEBUI_PORT=5111

# Interface to bind to.
# 127.0.0.1 = localhost only (default, recommended)
# 0.0.0.0   = all interfaces, reachable in local network
WEBUI_HOST=127.0.0.1

# Number of trusted reverse-proxy hops in front of Flask.
# Flask reads the real client IP from X-Forwarded-For, which makes
# rate-limiting and audit logging show the actual user IP instead of a
# Docker-internal proxy address.
# Only set this when you control ALL proxies in the chain and trust their headers.
#
# Examples:
#   0 = direct access, no proxy (default)
#   1 = single proxy, e.g. Traefik directly in front
#   2 = two proxies, e.g. nginx (LAN distributor) → Traefik (TLS + CrowdSec) → Flask
WEBUI_PROXY_COUNT=0

# Set to 1 when the app is served behind a TLS-terminating reverse proxy (e.g. Traefik).
# Adds the Secure flag to the session cookie so it is never sent over plain HTTP.
# Leave unset (or 0) for direct HTTP access without a proxy.
WEBUI_SECURE_COOKIES=0

# Set to 1 to omit absolute server-side paths (alerting directory, Python executable)
# from the /api/webui/info response. The cron-entry builder in the settings panel
# will fall back to generic placeholder text instead of the real paths.
WEBUI_HIDE_SERVER_PATHS=0

# Set to 1 to disable all write operations via the dashboard (config edits,
# rule changes, ignore-group, live test). Useful when sharing the UI.
WEBUI_READ_ONLY=0

# Set to 1 to enable Flask debug mode. Do NOT use in production or LAN deployments.
FLASK_DEBUG=0

# --- Alerting data directory (optional) ---

# Override where alerting stores config.json, state.json, and group_rules.json.
# Leave unset to use the default location (alerting/ directory next to monitor.py).
# Set this when running in Docker or when you want data files in a specific path.
# In Docker, this is set automatically via the Dockerfile (ALERTING_DATA_DIR=/app/data).
# ALERTING_DATA_DIR=/path/to/data
