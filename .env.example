# Get your API key at https://dashboard.remote-backups.com/settings/security
# Token scope: monitoring
API_KEY=your_api_key_here

# --- Web UI settings ---

# Port the web server listens on (default: 5111)
WEBUI_PORT=5111

# Interface to bind to.
# 127.0.0.1 = localhost only (default, recommended)
# 0.0.0.0   = all interfaces, reachable in local network
WEBUI_HOST=127.0.0.1

# Set to 1 to disable all write operations via the dashboard (config edits,
# rule changes, ignore-group, live test). Useful when sharing the UI.
WEBUI_READ_ONLY=0

# Set to 1 to enable Flask debug mode. Do NOT use in production or LAN deployments.
FLASK_DEBUG=0
